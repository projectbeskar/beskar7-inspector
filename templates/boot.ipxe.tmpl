#!ipxe
# Beskar7-Inspector iPXE Boot Script Template
# 
# Replace placeholders with actual values:
#   {{BOOT_SERVER}} - Your boot server URL (e.g., http://boot.example.com)
#   {{BESKAR7_API}} - Beskar7 API endpoint (e.g., http://beskar7-inspection.beskar7-system.svc.cluster.local:8082)
#   {{NAMESPACE}} - Kubernetes namespace (e.g., default)
#   {{HOSTNAME}} - PhysicalHost name (e.g., server-01)

echo ================================================
echo Beskar7-Inspector Network Boot
echo ================================================
echo .
echo Server: ${hostname}
echo MAC: ${net0/mac}
echo IP: ${net0/ip}
echo .

# Configure DHCP
dhcp || goto failed

# Boot parameters
set boot-server {{BOOT_SERVER}}
set beskar7-api {{BESKAR7_API}}
set beskar7-namespace {{NAMESPACE}}
set beskar7-host {{HOSTNAME}}

echo Booting Beskar7 Inspector...
echo API: ${beskar7-api}
echo Namespace: ${beskar7-namespace}
echo Host: ${beskar7-host}
echo .

# Download and boot kernel
kernel ${boot-server}/inspector/vmlinuz \
    beskar7.api=${beskar7-api} \
    beskar7.namespace=${beskar7-namespace} \
    beskar7.host=${beskar7-host} \
    console=tty0 \
    console=ttyS0,115200 \
    || goto failed

# Download initrd
initrd ${boot-server}/inspector/initrd.img || goto failed

# Boot
boot || goto failed

:failed
echo .
echo ================================================
echo Boot failed!
echo ================================================
echo .
echo Press any key to retry...
prompt --timeout 30
goto start

:start
# Retry boot
chain ${boot-server}/ipxe/inspect.ipxe

